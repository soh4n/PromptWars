# ── Google Cloud ─────────────────────────────────────────────────
GCP_PROJECT_ID=promptwars-demo
GCP_REGION=asia-south1

# ── PostgreSQL (Cloud SQL) ───────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=promptwars
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis (Memorystore) ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Firebase Auth ────────────────────────────────────────────────
FIREBASE_CREDENTIALS_BASE64=
FIREBASE_API_KEY=

# ── Vertex AI / Gemini ───────────────────────────────────────────
GEMINI_MODEL_FLASH=gemini-1.5-flash-002
GEMINI_MODEL_PRO=gemini-1.5-pro-002
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── Application ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
API_RATE_LIMIT_PER_MINUTE=60
INFERENCE_RATE_LIMIT_PER_MINUTE=10
LOG_LEVEL=INFO

# ── Frontend (Vite env vars) ────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=promptwars-demo
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
